# Embeddable Chatbot Builder — environment variables
# Copy to `.env` and adjust. Every value below has a sensible default,
# so the app runs out of the box with an empty `.env`.

# --- Database -------------------------------------------------------------
# Dev default: in-process PGlite (file-backed) — no Docker/Postgres needed.
# For production (e.g. Postgres on your DigitalOcean VPS), set DATABASE_URL:
#   DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=

# Directory for the local PGlite database (used only when DATABASE_URL is empty)
PGLITE_DIR=.pglite

# --- AI providers (optional) ---------------------------------------------
# With no keys set, the app runs in keyless mode:
#   - embeddings: local all-MiniLM-L6-v2 via transformers.js (real vector search)
#   - chat: extractive answerer grounded in retrieved context
# Set ONE of these to switch chat to a real LLM (embeddings stay local):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional model override (defaults picked per provider):
CHAT_MODEL=

# Directory for cached local model weights (downloaded once on first ingest)
MODEL_CACHE_DIR=.cache

# --- App ------------------------------------------------------------------
# Public base URL, used to build the embeddable widget snippet.
# Falls back to the incoming request origin when empty.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to a bot's publicId (after `npm run seed`, use "demo") to show the live
# demo chatbot on the landing page. Leave empty to hide it.
NEXT_PUBLIC_DEMO_BOT=
